<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <system.webServer>
        <rewrite>
            <rules>
                <!-- 1. ACME Challenge Exclusion -->
                <rule name="AcmeChallenge" stopProcessing="true">
                    <match url="^\.well-known/.*" />
                    <action type="None" />
                </rule>

                <!-- 2. Force HTTPS Redirect -->
                <rule name="ForceHTTPS" stopProcessing="true">
                    <match url="(.*)" />
                    <conditions>
                        <add input="{HTTPS}" pattern="off" ignoreCase="true" />
                    </conditions>
                    <action type="Redirect" url="https://{HTTP_HOST}/{R:1}" redirectType="Permanent" />
                </rule>

                <!-- 3. Explicit FastAPI Paths (Port 8000) -->
                <!-- Routes both pages and dashboard static files -->
                <rule name="FastAPIRouting" stopProcessing="true">
                    <match url="^(dashboard|login|logout|auth|api|rooms|attendance|participants|register|forgot-password|reset-password|static/)(.*)" />
                    <action type="Rewrite" url="http://127.0.0.1:8000/{R:0}" />
                </rule>

                <!-- 4. Jitsi Core Routing (Direct to Prosody 5280) -->
                <!-- Bypasses Jitsi Web proxying for critical XMPP components -->
                <rule name="ProsodyRouting" stopProcessing="true">
                    <match url="^(http-bind|xmpp-websocket)(.*)" />
                    <serverVariables>
                        <set name="HTTP_X_FORWARDED_PROTO" value="https" />
                    </serverVariables>
                    <action type="Rewrite" url="http://127.0.0.1:5280/{R:0}" />
                </rule>

                <!-- 5. Jitsi Assets Routing (Port 8080) -->
                <!-- Routes Jitsi room IDs (baknus-*) and Jitsi engine web files -->
                <rule name="JitsiRouting" stopProcessing="true">
                    <match url="^(external_api\.js|libs/|css/|static/|sounds/|fonts/|images/|lang/|favicon\.ico|pwa-worker\.js|manifest\.json|robot\.txt|all\.css|all\.js|close\.html|do-not-track\.html|baknus-)(.*)" />
                    <serverVariables>
                        <set name="HTTP_X_FORWARDED_PROTO" value="https" />
                    </serverVariables>
                    <action type="Rewrite" url="http://127.0.0.1:8080/{R:0}" />
                </rule>

                <!-- 6. Default Fallback (Try FastAPI, then Jitsi) -->
                <rule name="DefaultProxy" stopProcessing="true">
                    <match url="(.*)" />
                    <action type="Rewrite" url="http://127.0.0.1:8000/{R:1}" />
                </rule>
            </rules>
        </rewrite>
        <webSocket enabled="true" />
    </system.webServer>
</configuration>
